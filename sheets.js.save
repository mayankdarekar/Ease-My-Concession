const { google } = require('googleapis');
const path = require('path');

const SHEET_ID = '11bh23qfFTcuBeBEr-hPI1Mqn4IYhCqmBP8XWpSkmdCM';

async function getAuth() {
  const auth = new google.auth.GoogleAuth({
    keyFile: path.join(__dirname, 'credentials.json'),
    scopes: ['https://www.googleapis.com/auth/spreadsheets'],
  });
  return auth.getClient();
}

async function syncToSheet(student, application) {
  const client = await getAuth();
  const sheets = google.sheets({ version: 'v4', auth: client });
  await sheets.spreadsheets.values.append({
    spreadsheetId: SHEET_ID,
    range: 'Concessions!A:Z',
    valueInputOption: 'USER_ENTERED',
    requestBody: {
      values: [[
        '',
        application.pass_id || '',
        student.name,
        student.gender || '',
        new Date().toLocaleDateString('en-IN'),
        student.age || '',
        application.duration,
        student.branch,
        'Year ' + student.year,
        application.source_station,
        application.destination_station,
        student.address || '',
        student.dob ? new Date(student.dob).toLocaleDateString('en-IN') : '',
      ]],
    },
  });
}

module.exports = { syncToSheet };
